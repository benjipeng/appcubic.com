---
import { site } from "../data/site";
import BrandMark from "./BrandMark.astro";
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/appautomaton/", label: "AppAutomaton" },
  { href: "/about/", label: "About" },
];
---

<header class="site-header">
  <nav class="nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <BrandMark />
      <span class="brand-word" aria-hidden="true">
        <span class="seg">A</span><span class="seg fold fold-pp">pp</span><span class="seg">C</span><span class="seg fold fold-ubic">ubic</span><span class="seg slash">\</span>
      </span>
    </a>
    <div class="nav-links">
      {
        links.map((link) => (
          <a href={link.href} class:list={["nav-link", Astro.url.pathname === link.href && "active"]}>
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="nav-actions">
      <ThemeToggle />
      <a class="nav-cta" href={site.links.benji}>Benji</a>
    </div>
  </nav>
</header>

<style>
  /* Scrolling away from the top folds "AppCubic" into "AC\": the interior
     letters hinge shut like paper (staggered, with spring overshoot) and the
     backslash swings in as the cube's closing edge. */
  .brand-word {
    display: inline-flex;
    align-items: baseline;
    perspective: 320px;
    white-space: nowrap;
  }

  .seg {
    display: inline-block;
    transform-origin: left center;
  }

  .fold {
    max-width: 3em;
    opacity: 1;
    transform: rotateY(0deg);
    transition:
      max-width 0.55s cubic-bezier(0.68, -0.55, 0.27, 1.4),
      opacity 0.4s ease,
      transform 0.55s cubic-bezier(0.68, -0.55, 0.27, 1.4);
  }

  .fold-ubic { transition-delay: 0s; }
  .fold-pp { transition-delay: 0.09s; }

  .slash {
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    transform: rotate(-100deg) translateY(0.08em);
    transform-origin: 30% 70%;
    color: var(--accent);
    transition:
      max-width 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.3s ease,
      transform 0.6s cubic-bezier(0.34, 1.8, 0.5, 1);
  }

  :global(.brand.folded) .fold {
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    transform: rotateY(92deg) skewX(-14deg);
  }

  :global(.brand.folded) .fold-pp { transition-delay: 0s; }
  :global(.brand.folded) .fold-ubic { transition-delay: 0.09s; }

  :global(.brand.folded) .slash {
    max-width: 0.7em;
    opacity: 1;
    transform: rotate(0deg) translateY(0);
    transition-delay: 0.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .fold,
    .slash {
      transition: none;
    }
  }
</style>

<script>
  const brand = document.querySelector(".brand");
  if (brand) {
    let ticking = false;
    const update = () => {
      brand.classList.toggle("folded", window.scrollY > 70);
      ticking = false;
    };
    window.addEventListener("scroll", () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }, { passive: true });
    update();
  }
</script>
