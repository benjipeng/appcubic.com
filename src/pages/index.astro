---
import Footer from "../components/Footer.astro";
import HeroArt from "../components/HeroArt.astro";
import Nav from "../components/Nav.astro";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ChartNoAxesCombined, ShieldCheck, Workflow } from "@lucide/astro";
---

<BaseLayout title={site.title} description={site.description} pathname="/">
  <Nav />
  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-content">
        <div class="hero-text">
          <p class="eyebrow">AppCubic · Applied AI studio · Building since 2019</p>
          <h1 id="hero-title">AI systems that hold up <em>in real work</em>.</h1>
          <p class="hero-copy">
            Agent workflows, research tooling, and the products that grow out of them — built,
            tested, and carried to production by a small studio that ships.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="/about/">Explore the studio</a>
            <a class="button secondary" href={site.links.research}>Research systems</a>
          </div>
        </div>
        <div class="hero-figure">
          <HeroArt />
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="services-title">
      <div class="section-shell">
        <div class="section-header">
          <p class="section-label">Focus areas</p>
          <h2 id="services-title">What the studio <em>builds</em>.</h2>
          <p>
            The work sits where prototypes have to become dependable: agent workflows, technical
            products, scientific tooling, and the operations around them.
          </p>
        </div>
        <div class="bento">
          <article class="bento-cell bento-feature">
            <p class="bento-kicker">Agentic systems</p>
            <h3>App Automaton, the studio's <em>open workshop</em>.</h3>
            <p>
              Portable skills for coding agents, document and web tooling, multi-agent
              orchestration, and local models for Apple Silicon. Built in public, shaped by daily
              use inside the studio.
            </p>
            <div class="bento-term" aria-hidden="true">
              <span class="t-prompt">$</span>
              <span class="t-cmd">gh repo clone appautomaton/agent-designer</span>
              <span class="t-ok">✓ skills · bridges · issue-driven workflow</span>
            </div>
            <svg class="bento-cubes" viewBox="0 0 160 110" fill="none" aria-hidden="true">
              <polygon class="c-a left" points="30.6,50 60,67 60,101 30.6,84"></polygon>
              <polygon class="c-a right" points="89.4,50 60,67 60,101 89.4,84"></polygon>
              <polygon class="c-a top" points="60,33 89.4,50 60,67 30.6,50"></polygon>
              <polygon class="c-b left" points="104.4,40 120,49 120,67 104.4,58"></polygon>
              <polygon class="c-b right" points="135.6,40 120,49 120,67 135.6,58"></polygon>
              <polygon class="c-b top" points="120,31 135.6,40 120,49 104.4,40"></polygon>
            </svg>
            <a class="bento-link" href={site.links.appautomaton}>Explore App Automaton</a>
          </article>

          <article class="bento-cell bento-half">
            <p class="bento-kicker">Research to product</p>
            <h3>Workflows that ship.</h3>
            <p>
              Scientific and analytical workflows turned into systems people can actually run,
              built for correctness and repeatability. One example is{" "}
              <a href={site.links.mlxAtomistic}>mlx-atomistic</a>, an Apple-Silicon molecular
              dynamics and density functional theory runtime that runs on the Mac GPU.
            </p>
            <a class="bento-link" href={site.links.research}>Research systems</a>
          </article>

          <article class="bento-cell bento-half">
            <p class="bento-kicker">Venture &amp; advisory</p>
            <h3>From diligence to incubation.</h3>
            <p>
              Early product strategy, technical diligence, grant support, and incubation for
              AI-first products.
            </p>
            <a class="bento-link" href="/about/">About the studio</a>
          </article>

          <article class="bento-cell bento-wide">
            <div>
              <p class="bento-kicker">Open source</p>
              <p>MIT-licensed tooling, public on GitHub and in daily use.</p>
            </div>
            <a class="bento-link" href={site.links.appautomatonOrg}>github.com/appautomaton</a>
          </article>

          <article class="bento-cell bento-half bento-stat">
            <p class="bento-stat-num">2019</p>
            <p class="bento-stat-lbl">Building since</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section alt" aria-labelledby="principles-title">
      <div class="section-shell">
        <div class="section-header centered">
          <p class="section-label">Operating principles</p>
          <h2 id="principles-title">How we <em>work</em>.</h2>
          <p>
            AppCubic is a small AI engineering studio. We build, test, and carry agentic systems
            toward production with teams who know their domain deeply.
          </p>
        </div>
        <div class="proof-grid">
          <article class="principle">
            <div class="principle-kicker">
              <span class="principle-icon">
                <ShieldCheck size={20} stroke-width={1.8} />
              </span>
            </div>
            <h3>Reliable by design</h3>
            <p>
              Agents earn trust through evaluation, careful retrieval, and explicit tool
              boundaries. We engineer for behavior you can predict.
            </p>
          </article>
          <article class="principle">
            <div class="principle-kicker">
              <span class="principle-icon">
                <Workflow size={20} stroke-width={1.8} />
              </span>
            </div>
            <h3>Whole systems, not demos</h3>
            <p>
              We build end-to-end workflows shaped by real operating constraints, not isolated
              prompt experiments that break the first time conditions change.
            </p>
          </article>
          <article class="principle">
            <div class="principle-kicker">
              <span class="principle-icon">
                <ChartNoAxesCombined size={20} stroke-width={1.8} />
              </span>
            </div>
            <h3>Depth that compounds</h3>
            <p>
              Technical depth speeds up learning. Good data infrastructure, scientific rigor, and
              product judgment reinforce one another.
            </p>
          </article>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
