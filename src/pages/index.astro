---
import Nav from "../components/Nav.astro";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={site.title} description={site.description} pathname="/">
  <Nav />
  <main>
    <!-- The monument: type is the hero -->
    <section class="hero" aria-labelledby="hero-title">
      <p class="hero-manifesto">
        AppCubic is an applied AI studio. Since 2019 it has built agent workflows, research
        tooling, and the products that grow out of them — carried all the way to production.
      </p>
      <div class="hero-index" aria-hidden="true">
        APPLIED AI STUDIO<br />
        EST. 2019<br />
        SYSTEMS · RESEARCH · VENTURES
      </div>
      <h1 class="monument" id="hero-title">
        <span class="word"><span class="ln" style="--i:0">Applied</span></span><span
          class="word"><span class="ln" style="--i:1"><em>AI.</em></span></span>
      </h1>
      <p class="hero-foot" id="scroll-hint">Scroll to explore</p>
    </section>

    <!-- Statement -->
    <section class="statement" data-reveal aria-label="Studio statement">
      <p>
        <span class="ln-mask"><span class="ln" style="--i:0">Prototypes are easy. We build the systems</span></span>
        <span class="ln-mask"><span class="ln" style="--i:1">that survive contact with <em>real work</em> —</span></span>
        <span class="ln-mask"><span class="ln" style="--i:2">and we carry them to production.</span></span>
      </p>
    </section>

    <!-- The ledger -->
    <div class="ledger" aria-label="What the studio builds">
      <p class="ledger-label">The ledger — what the studio builds</p>

      <a class="row" href={site.links.appautomaton}>
        <div class="row-inner">
          <h2>App Automaton</h2>
          <span class="meta">Agentic systems — open source</span>
        </div>
        <p class="desc">
          Portable skills for coding agents, multi-agent orchestration, and pure-MLX models
          for Apple Silicon. MIT-licensed, in daily studio use.
        </p>
      </a>

      <a class="row" href={site.links.research}>
        <div class="row-inner">
          <h2>Research Systems</h2>
          <span class="meta">Science to product</span>
        </div>
        <p class="desc">
          Molecular dynamics and density functional theory on the Mac GPU — scientific
          workflows turned into systems people can actually run.
        </p>
      </a>

      <a class="row" href="/about/">
        <div class="row-inner">
          <h2>Venture Studio</h2>
          <span class="meta">Diligence — incubation</span>
        </div>
        <p class="desc">
          Early product strategy, technical diligence, grant support, and incubation for
          AI-first products.
        </p>
      </a>
    </div>

    <!-- Marquee belt -->
    <div class="belt" aria-hidden="true">
      <div class="belt-track" id="belt">
        <span>Built <b>in public</b></span><span>Shipped <b>to production</b></span><span>Reliable <b>by design</b></span><span>Since <b>2019</b></span><span>Built <b>in public</b></span><span>Shipped <b>to production</b></span><span>Reliable <b>by design</b></span><span>Since <b>2019</b></span>
      </div>
    </div>

    <!-- Creed -->
    <section class="creed" data-reveal aria-label="Operating principles">
      <div class="creed-item">
        <h3 class="rv" style="--d:0">Reliable by design.</h3>
        <p class="rv" style="--d:1">
          Agents earn trust through evaluation, careful retrieval, and explicit tool
          boundaries. We engineer for behavior you can predict.
        </p>
      </div>
      <div class="creed-item">
        <h3 class="rv" style="--d:0">Whole systems, not demos.</h3>
        <p class="rv" style="--d:1">
          End-to-end workflows shaped by real operating constraints — not isolated prompt
          experiments that break when conditions change.
        </p>
      </div>
      <div class="creed-item">
        <h3 class="rv" style="--d:0">Depth that compounds.</h3>
        <p class="rv" style="--d:1">
          Good data infrastructure, scientific rigor, and product judgment reinforce one
          another.
        </p>
      </div>
    </section>

    <!-- Coda: night sky, cube assembles, monument returns as outline -->
    <footer class="coda" id="coda">
      <canvas class="coda-sky" id="coda-sky" aria-hidden="true"></canvas>
      <p class="coda-copy">
        A small studio that ships. If the work above sounds like the work you need, the
        door is open.
        <a class="coda-cta" href="/about/">Visit the studio</a>
      </p>
      <nav class="coda-links" aria-label="Footer navigation">
        <a href="/about/">About</a>
        <a href="/appautomaton/">AppAutomaton</a>
        <a href={site.links.github}>GitHub</a>
        <a href={site.links.benji}>Benji</a>
      </nav>
      <div class="monument" aria-hidden="true"><span class="word">AppCubic</span></div>
      <div class="coda-foot">
        <span>©2026 AppCubic</span>
        <span id="coda-clock"></span>
      </div>
    </footer>
  </main>
</BaseLayout>

<script>
  import Lenis from "lenis";
  import { mountConstellation } from "../scripts/constellation.js";

  const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* smooth scroll */
  if (!reduced) {
    const lenis = new Lenis({ lerp: 0.09 });
    const raf = (t: number) => {
      lenis.raf(t);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
  }

  /* load: monument rises */
  requestAnimationFrame(() =>
    requestAnimationFrame(() => document.body.classList.add("loaded"))
  );

  /* reveals */
  const io = new IntersectionObserver(
    (es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.3 }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) =>
    reduced ? el.classList.add("in") : io.observe(el)
  );

  /* marquee: time drift + scroll coupling */
  const belt = document.getElementById("belt");
  const hint = document.getElementById("scroll-hint");
  if (belt && !reduced) {
    const tick = (now: number) => {
      const half = belt.scrollWidth / 2;
      if (half > 0) {
        const x = -((now * 0.04 + scrollY * 0.35) % half);
        belt.style.transform = `translate3d(${x.toFixed(1)}px,0,0)`;
      }
      if (hint) hint.style.opacity = scrollY > 80 ? "0" : "1";
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  /* coda constellation */
  const sky = document.getElementById("coda-sky") as HTMLCanvasElement | null;
  const coda = document.getElementById("coda");
  if (sky && coda) mountConstellation(sky, coda);

  /* coda clock */
  const clock = document.getElementById("coda-clock");
  if (clock) {
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const tick = () => {
      const d = new Date();
      const f = (z: string) =>
        d.toLocaleTimeString("en-US", {
          timeZone: z,
          hour12: false,
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });
      clock.textContent = `${f(tz)} local · ${f("UTC")} UTC`;
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
